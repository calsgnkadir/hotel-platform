# Bu dosyayı kopyala → .env adıyla kaydet → kendi değerlerini yaz
# .env dosyasını asla git'e push etme! (.gitignore'a ekle)

# Veritabanı
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hotel_platform
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# JWT — en az 32 karakter, rastgele üret:
# Linux/Mac: openssl rand -base64 48
# Windows:   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=buraya-en-az-32-karakterlik-rastgele-bir-deger-yaz

# Cloudinary (foto + belge yükleme — F1-F9)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# https://cloudinary.com/console
CLOUDINARY_URL=

# #80 — Email (Resend) ile şifre sıfırlama
# https://resend.com/api-keys → "Create API Key" → kopyala
# Boş bırakırsan: email DEV mode'da log'a düşer (gerçek inbox'a gitmez), test edebilirsin.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_FROM_NAME=AjansHotel

# Frontend URL — reset linki email'de bunu kullanır
# Dev: http://localhost:5173 (Vite varsayılan)
# Prod: https://hotel-platform-seven.vercel.app
APP_BASE_URL=http://localhost:5173

# Opsiyoneller (default değerleri var, değiştirmek zorunda değilsin)
SERVER_PORT=8080
JWT_EXPIRATION=86400000
FILE_UPLOAD_DIR=./uploads
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=WARN
PWD_RESET_EXPIRY_HOURS=1
